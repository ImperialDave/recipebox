# Firebase Client SDK (from Firebase Console > Project Settings > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin SDK (from Firebase Console > Project Settings > Service Accounts > Generate new private key)
# Paste the entire JSON contents as a single line string
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# App URL (used for magic link redirects and sign-out)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Recipe photo scanning (Google Gemini Flash)
GEMINI_API_KEY=your-gemini-api-key
RECIPE_SCAN_DAILY_LIMIT=20
RECIPE_SCAN_MAX_IMAGE_MB=10